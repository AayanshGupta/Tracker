# =============================================================================
# Task Tracker — Production Environment Variables
# Use this as a checklist when deploying to production.
# Set these as environment variables in your hosting platform's dashboard
# (Vercel, Railway, Fly.io, etc.) — do NOT store this as a file on the server.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────
# Use a production-grade managed PostgreSQL (e.g. Neon, Supabase, Railway, RDS)
# Enable connection pooling (e.g. PgBouncer) for serverless deployments
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/task_tracker?schema=public&sslmode=require&pgbouncer=true"
# If your provider requires a direct (non-pooled) URL for migrations:
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/task_tracker?schema=public&sslmode=require"

# ── Auth.js ───────────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -base64 32
# This must be a long, random, secret string — never reuse dev secrets
AUTH_SECRET="<run: openssl rand -base64 32>"

# Set to your production domain (no trailing slash)
AUTH_URL="https://yourdomain.com"

# ── App Config ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPPORT_EMAIL="support@yourcompany.com"

# ── Security Notes ────────────────────────────────────────────────────────
# 1. DATABASE_URL must use sslmode=require in production
# 2. AUTH_SECRET must be unique per environment
# 3. Never log these values — check your hosting platform's log masking
# 4. Rotate AUTH_SECRET if it is ever exposed — all sessions will be invalidated
# 5. Run migrations separately before deploying: npm run db:deploy
