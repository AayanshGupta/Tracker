# =============================================================================
# Task Tracker — Environment Variables Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env — only .env.example should be in version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/task_tracker?schema=public"

# ── Auth.js ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"

# The canonical base URL of the app (no trailing slash)
AUTH_URL="http://localhost:3000"

# ── App Config ────────────────────────────────────────────────────────────
# Support contact shown to users
NEXT_PUBLIC_SUPPORT_EMAIL="support@yourcompany.com"
